# ── BV Archery Battle — variables de entorno (API) ──
# Copiar a .env (no se commitea). Valores de ejemplo para desarrollo local.
# La fuente de verdad es packages/api/src/env.ts.

# development | production | test
NODE_ENV=development

# Puerto del servidor (sirve /api + frontend en producción).
PORT=8787

# Ruta del archivo SQLite. En producción montar en un volumen persistente (ej. /data/app.db).
DATABASE_PATH=./data/app.db

# Carpeta del build del frontend que sirve la API en producción (relativa al cwd de la API).
WEB_DIST=public

# Secreto de sesión. OBLIGATORIO en producción: >=16 caracteres y distinto del default.
# Generar uno seguro:  openssl rand -hex 32
SESSION_SECRET=dev-insecure-secret-change-me
SESSION_TTL_DAYS=30

# Flag Secure de las cookies. Forzar true en producción (HTTPS).
COOKIE_SECURE=false

# Origen permitido para CORS (solo dev; en prod el front se sirve del mismo origen).
CORS_ORIGIN=http://localhost:5173

# Rate limiting
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=120
AUTH_RATE_LIMIT_MAX=10
LOGIN_MAX_ATTEMPTS=8
LOGIN_LOCK_MINUTES=15

# debug | info | warn | error
LOG_LEVEL=info
